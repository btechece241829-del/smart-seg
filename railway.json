{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "cd mall_segmentation && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd mall_segmentation && gunicorn --workers 1 --threads 4 --timeout 120 app:app",
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
